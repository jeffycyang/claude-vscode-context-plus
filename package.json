{
  "name": "claude-code-context-plus",
  "displayName": "Claude Code Context Plus",
  "description": "Add files and selections to Claude Code terminal context via right-click menus and keyboard shortcuts",
  "version": "0.1.0",
  "publisher": "jeffycyang",
  "repository": {
    "type": "git",
    "url": "https://github.com/jeffycyang/claude-vscode-context-plus.git"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "ai",
    "context"
  ],
  "icon": "resources/icon.png",
  "galleryBanner": {
    "color": "#D97706",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claudeContextPlus.addFileToContext",
        "title": "Add to Claude Code",
        "category": "Claude Code Context Plus"
      },
      {
        "command": "claudeContextPlus.sendSelectionToContext",
        "title": "Send Selection to Claude Code",
        "category": "Claude Code Context Plus"
      },
      {
        "command": "claudeContextPlus.setAsClaudeTerminal",
        "title": "Set as Claude Code Terminal",
        "category": "Claude Code Context Plus"
      },
      {
        "command": "claudeContextPlus.selectTerminal",
        "title": "Select Claude Code Terminal",
        "category": "Claude Code Context Plus"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "claudeContextPlus.addFileToContext",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "claudeContextPlus.sendSelectionToContext",
          "when": "editorHasSelection",
          "group": "navigation"
        }
      ],
      "editor/title/context": [
        {
          "command": "claudeContextPlus.addFileToContext",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "claudeContextPlus.addFileToContext",
        "key": "ctrl+shift+.",
        "mac": "cmd+shift+.",
        "when": "editorFocus"
      },
      {
        "command": "claudeContextPlus.sendSelectionToContext",
        "key": "ctrl+shift+,",
        "mac": "cmd+shift+,",
        "when": "editorHasSelection"
      }
    ],
    "configuration": {
      "title": "Claude Code Context Plus",
      "properties": {
        "claudeContextPlus.terminalNamePatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional terminal name patterns to match as Claude Code terminals (regex supported)"
        }
      }
    }
  },
  "scripts": {
    "build": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "build:prod": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --minify",
    "launch": "npm run build && code --extensionDevelopmentPath=.",
    "watch": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "npm run build:prod && npx @vscode/vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0",
    "esbuild": "^0.24.0",
    "vitest": "^2.0.0",
    "@vscode/vsce": "^3.0.0"
  }
}
